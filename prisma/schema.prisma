generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EmailBlastStatus {
  draft
  pending_approval
  approved
  rejected
  sent
}

model EmailBlast {
  id              String            @id @default(cuid())
  subject         String
  body            String
  contentMode     String            @default("text")
  senderName      String?
  senderEmail     String?
  replyToEmail    String?
  status          EmailBlastStatus  @default(draft)
  composedBy      String
  approvedBy      String?
  rejectedBy      String?
  rejectionReason String?
  sentAt          DateTime?
  sentCount       Int               @default(0)
  departmentId    String
  isArchived      Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  recipients      EmailBlastRecipient[]
  attachments     EmailBlastAttachment[]

  @@index([departmentId, createdAt])
  @@index([status])
}

model EmailBlastRecipient {
  id      String     @id @default(cuid())
  blastId String
  email   String
  blast   EmailBlast @relation(fields: [blastId], references: [id], onDelete: Cascade)

  @@index([blastId])
  @@index([email])
  @@unique([blastId, email])
}

model EmailBlastAttachment {
  id             String     @id @default(cuid())
  blastId        String
  kind           String
  storageKey     String
  publicUrl      String?
  filename       String
  mimeType       String
  sizeBytes      Int
  checksumSha256 String
  uploadedBy     String
  createdAt      DateTime   @default(now())
  blast          EmailBlast @relation(fields: [blastId], references: [id], onDelete: Cascade)

  @@index([blastId, createdAt])
  @@index([checksumSha256])
  @@unique([blastId, checksumSha256])
}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  sessions      Session[]
  accounts      Account[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

