generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EmailBlastStatus {
  draft
  pending_approval
  approved
  rejected
  sent
}

model EmailBlast {
  id              String            @id @default(cuid())
  subject         String
  body            String
  senderName      String?
  senderEmail     String?
  replyToEmail    String?
  status          EmailBlastStatus  @default(draft)
  composedBy      String
  approvedBy      String?
  rejectedBy      String?
  rejectionReason String?
  sentAt          DateTime?
  sentCount       Int               @default(0)
  departmentId    String
  isArchived      Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  recipients      EmailBlastRecipient[]

  @@index([departmentId, createdAt])
  @@index([status])
}

model EmailBlastRecipient {
  id      String     @id @default(cuid())
  blastId String
  email   String
  blast   EmailBlast @relation(fields: [blastId], references: [id], onDelete: Cascade)

  @@index([blastId])
  @@index([email])
  @@unique([blastId, email])
}
